{
  "name": "custom-design-portal",
  "version": "1.0.0",
  "description": "Custom Design Submission Portal for Fashion Brand - Eleventy Frontend with Google Apps Script Backend",
  "main": "index.js",
  "scripts": {
    "start": "eleventy --serve",
    "build": "eleventy",
    "clean": "rimraf _site",
    "rebuild": "npm run clean && npm run build",
    "deploy:prepare": "npm run build",
    "dev": "eleventy --serve --port=8080"
  },
  "keywords": [
    "eleventy",
    "11ty",
    "static-site",
    "fashion",
    "design-portal",
    "google-apps-script"
  ],
  "author": "Fashion Brand Tech Team",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "markdown-it": "^14.0.0",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/custom-design-portal.git"
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  }
}
